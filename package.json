{
  "name": "ross-course-base",
  "version": "1.0.0",
  "description": "MCP knowledge server for Ross MBA Canvas course materials",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/server.ts",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:dry": "DRY_RUN=true tsx scripts/ingest.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.0",
    "cheerio": "^1.0.0",
    "gpt-tokenizer": "^2.8.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
