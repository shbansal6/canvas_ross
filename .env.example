# Canvas API
CANVAS_BASE_URL=https://umich.instructure.com
CANVAS_API_TOKEN=your_canvas_personal_access_token_here

# Google Gemini (used for embeddings during ingestion AND at query time in the MCP server)
GEMINI_API_KEY=your_google_ai_studio_key_here

# Supabase (add after creating your project at supabase.com)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# MCP Server (optional)
# PORT=3000
